# Скопировать в .env и заполнить реальными значениями:
# cp .env.example .env
#
# Или использовать deploy/setup.sh — он сгенерирует .env автоматически.

# === Production (docker-compose.prod.yml) ===

# PostgreSQL credentials
DB_USER=ochag_user
DB_PASSWORD=          # Генерируется через: openssl rand -base64 24

# JWT token signing key
JWT_SECRET=           # Генерируется через: openssl rand -base64 32
